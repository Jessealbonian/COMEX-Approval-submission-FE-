# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=3000
NODE_ENV=development

# When you deploy frontend and backend on different hosts, list every
# allowed origin here, comma-separated. NEVER use "*" together with
# CORS_CREDENTIALS=true (the browser will reject it).
#
# Examples:
#   CORS_ORIGIN=http://localhost:4200
#   CORS_ORIGIN=https://comex.example.com,https://staging.comex.example.com
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=false

# Set to 1 (or "true") when running behind a reverse proxy / load balancer
# (Heroku, Render, Nginx, Cloudflare, etc.) so req.ip + rate limiting work.
TRUST_PROXY=0

# ---------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=comex_approval
DB_CONNECTION_LIMIT=10

# Set DB_SSL=true when the managed DB requires TLS (PlanetScale, AWS RDS,
# Azure Database for MySQL, etc.). DB_SSL_REJECT_UNAUTHORIZED defaults to true.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------
# Auth (REQUIRED in production)
# ---------------------------------------------------------------
# Generate a strong secret, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production the server REFUSES to start if this is missing or weak (<32 chars).
JWT_SECRET=replace-this-with-a-long-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=1d
JWT_ISSUER=comex-approval-api
JWT_AUDIENCE=comex-approval-app
BCRYPT_SALT_ROUNDS=12

# ---------------------------------------------------------------
# Uploads
# ---------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20

# ---------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# ---------------------------------------------------------------
# Seed admin (used by `npm run db:seed`)
# ---------------------------------------------------------------
SEED_ADMIN_NAME=Principal Admin
SEED_ADMIN_EMAIL=admin@comex.local
SEED_ADMIN_PASSWORD=Admin@12345
